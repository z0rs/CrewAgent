# ─── LLM API Keys ──────────────────────────────────────────────────────────────
# Budget mode (single-Claude): only ANTHROPIC_API_KEY is required.
# Multi-agent mode: set all three keys.
#
# BUDGET MODE (ANTHROPIC_API_KEY only):
#   → Runs the full pentest pipeline with ONE Claude agent.
#   → Only this key is needed; leave GOOGLE_API_KEY and OPENAI_API_KEY empty.
#
# MULTI-AGENT MODE (all 3 keys):
#   → http_analyst    → Gemini (GOOGLE_API_KEY)
#   → validation_executor → GPT-4o (OPENAI_API_KEY)
#   → lead_pentester  → Claude (ANTHROPIC_API_KEY)
#   → report_generator → Claude (ANTHROPIC_API_KEY)

# ─── REQUIRED for both modes ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Required only for multi-agent mode ────────────────────────────────────────
GOOGLE_API_KEY=
OPENAI_API_KEY=

# ─── Burp Suite MCP Configuration ──────────────────────────────────────────────
BURP_MCP_HOST=127.0.0.1
BURP_MCP_PORT=9876

# ─── Engagement Configuration ──────────────────────────────────────────────────
# ENGAGEMENT_ID: auto-generated if not set (format: ENG-YYYYMMDD-HHMM)
ENGAGEMENT_ID=
CLIENT_NAME=Client
TEST_TYPE=greybox
TESTER_NAME=Security Team
REPORT_OUTPUT_DIR=./reports

# ─── Optional Tuning ───────────────────────────────────────────────────────────
# Override the default 30s wait in poll_collaborator_with_wait
# COLLABORATOR_WAIT_SECS=30
