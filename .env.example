# ─── LLM API Keys ──────────────────────────────────────────────────────────────
# Gemini (Agent 1 - Analyst)
GOOGLE_API_KEY=<>

# OpenAI Codex / GPT-4 (Agent 2 - Executor)
OPENAI_API_KEY=<>

# Anthropic Claude (Agent 3 - Reviewer & Agent 4 - Reporter)
ANTHROPIC_API_KEY=<>

# ─── Burp Suite MCP Configuration ──────────────────────────────────────────────
