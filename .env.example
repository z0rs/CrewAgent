# ─── LLM API Keys ──────────────────────────────────────────────────────────────
# Gemini (Agent 1 - Analyst)
GOOGLE_API_KEY=your_gemini_api_key_here

# OpenAI Codex / GPT-4 (Agent 2 - Executor)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude (Agent 3 - Reviewer & Agent 4 - Reporter)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Burp Suite MCP Configuration ──────────────────────────────────────────────
BURP_MCP_HOST=127.0.0.1
BURP_MCP_PORT=9876

# ─── Engagement Configuration ──────────────────────────────────────────────────
ENGAGEMENT_ID=ENG-2026-001
TARGET_URL=https://target.example.com
TEST_TYPE=greybox
CLIENT_NAME=Example Client
TESTER_NAME=Security Team
REPORT_OUTPUT_DIR=./reports

# ─── Optional Tuning ───────────────────────────────────────────────────────────
# Override the default 30s wait in poll_collaborator_with_wait
# COLLABORATOR_WAIT_SECS=30