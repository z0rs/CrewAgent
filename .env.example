# ─── LLM API Keys ──────────────────────────────────────────────────────────────
# Configure ONE or MORE keys. The crew auto-detects:
#   • Exactly 1 key  → single-agent mode (one LLM runs everything)
#   • 2+ keys       → multi-agent mode (each role gets its preferred LLM)
#
# PROVIDER MAPPING (multi-agent fallback chain if preferred key is missing):
#   http_analyst         → Google → OpenAI → Anthropic → OpenRouter
#   validation_executor  → OpenAI → Anthropic → Google → OpenRouter
#   lead_pentester       → Anthropic → OpenAI → Google → OpenRouter
#   report_generator     → Anthropic → OpenAI → Google → OpenRouter
#   pentester (single)   → Anthropic → OpenAI → Google → OpenRouter

# ─── Required ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Optional ───────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=
OPENAI_API_KEY=

# ─── OpenRouter (unified gateway — one key, hundreds of models) ─────────────────
# Set OPENROUTER_API_KEY to enable. Use https://openrouter.ai/keys to get one.
# FREE MODELS for testing (verified available on your account):
#   openai/gpt-oss-120b:free         ← 120B, 131k context, good quality
#   openai/gpt-oss-20b:free          ← 20B, 131k context
#   google/gemma-3-27b-it:free       ← Gemma 3 27B, 131k context
#   meta-llama/llama-3.3-70b-instruct:free  ← 70B, 65k context
#   nousresearch/hermes-3-llama-3.1-405b:free  ← 405B, 131k context
#   inclusionai/ling-2.6-1t:free    ← 2.6T MoE, 262k context
#   nvidia/nemotron-3-super-120b-a12b:free  ← 120B, 262k context
#   nvidia/nemotron-3-nano-30b-a3b:free    ← 30B, 256k context
#   qwen/qwen3-coder:free           ← Qwen Coder, 262k context
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── Per-Role Model Overrides ───────────────────────────────────────────────────
# Override the model used by a specific role.
# Format: provider/model (e.g. "openrouter/meta-llama/llama-3-8b")
#         or just model name (e.g. "gpt-4o") — provider auto-inferred from fallback chain
#
# Uncomment to use; leave blank to use the provider's default model.
# MODEL_PENTESTER=openrouter/nexus/NexusRyrin-70B
# MODEL_ANALYST=openrouter/google/gemini-2.0-flash-thinking
# MODEL_EXECUTOR=openrouter/deepseek/deepseek-chat-v3
# MODEL_REVIEWER=anthropic/claude-sonnet-4-5
# MODEL_REPORTER=openrouter/mistralai/mistral-nemo

# ─── Burp Suite MCP Configuration ──────────────────────────────────────────────
BURP_MCP_HOST=127.0.0.1
BURP_MCP_PORT=9876

# ─── Engagement Configuration ──────────────────────────────────────────────────
# ENGAGEMENT_ID: auto-generated if not set (format: ENG-YYYYMMDD-HHMM)
ENGAGEMENT_ID=
CLIENT_NAME=Client
TEST_TYPE=greybox
TESTER_NAME=Security Team
REPORT_OUTPUT_DIR=./reports

# ─── Optional Tuning ──────────────────────────────────────────────────────────
# Override the default 30s wait in poll_collaborator_with_wait
COLLABORATOR_WAIT_SECS=30
