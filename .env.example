BURP_MCP_PORT=9876

# Burp Suite REST API (for direct REST calls if needed)
BURP_REST_API_URL=http://127.0.0.1:1337
BURP_REST_API_KEY=<>

# ─── Engagement Configuration ──────────────────────────────────────────────────
